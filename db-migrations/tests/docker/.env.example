# Template for .env.local (gitignored). setup.ps1 generates .env.local with
# strong random values if it is missing — you normally never edit this by hand.
# Copy to .env.local and fill in only if you want fixed, reproducible secrets.
#
# Both values must satisfy SQL Server password complexity (>= 8 chars, 3 of:
# upper / lower / digit / symbol). CertPassword additionally must NOT contain a
# single quote (') — it is substituted textually into a single-quoted SQL literal
# by the Ebene-B signing chain (see db-migrations/deploy.ps1, global/up/0011).

# SA password for the container (compose reads this; also used by SQL-auth deploys).
MSSQL_SA_PASSWORD=ChangeMe_Strong1!

# RoboticoOpsSigning certificate password for `-Scope global` deploys
# (grate {{CertPassword}} token). No single quote.
GRATE_CERT_PASSWORD=ChangeMe_Cert1!
